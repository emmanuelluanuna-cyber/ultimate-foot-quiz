{"design_system": "Quizio UI Kit","version": "1.0.0","metadata": {"style_keywords": ["Modern", "Gamified", "Playful", "Rounded", "High Contrast", "Clean"],"target_platform": "Mobile (iOS/Android)","primary_geometry": "Rounded Rectangles (16px-24px radius)"},"design_tokens": {"colors": {"brand": {"primary": "#6A5AE0","secondary": "#9087E5","accent": "#FF8F3E"},"functional": {"success": "#53D1B6","error": "#FF6B6B","warning": "#FFBE3C","info": "#4A90E2"},"neutral": {"background": "#FFFFFF","surface": "#F4F3FD","text_primary": "#0C092A","text_secondary": "#858494","border": "#EFEEFC"}},"typography": {"font_family": "Google Fonts (Inter/Poppins)","scales": {"display": { "size": "32px", "weight": "700", "letter_spacing": "-0.5px" },"h1": { "size": "24px", "weight": "700" },"h2": { "size": "20px", "weight": "600" },"body_lg": { "size": "16px", "weight": "500" },"body_md": { "size": "14px", "weight": "400" },"caption": { "size": "12px", "weight": "400", "color": "text_secondary" }}},"spacing": {"base_unit": 8,"container_padding": 24,"component_gap": 16,"card_inner_padding": 20},"shadows": {"card": "0px 8px 24px rgba(106, 90, 224, 0.08)","button_primary": "0px 10px 20px rgba(106, 90, 224, 0.2)"}},"component_structure": {"question_card": {"layout": "Vertical Stack","elements": [{ "id": "progress_bar", "type": "Linear", "height": "8px" },{ "id": "question_text", "type": "h2", "alignment": "Center", "margin_top": "32px" },{ "id": "option_list", "type": "Button Group", "spacing": "12px" }],"states": {"default": { "border": "2px solid neutral.border", "bg": "white" },"selected": { "border": "2px solid brand.primary", "bg": "surface" },"correct": { "border": "2px solid functional.success", "bg": "functional.success_light" },"incorrect": { "border": "2px solid functional.error", "bg": "functional.error_light" }}},"category_chip": {"layout": "Horizontal Row","elements": ["Icon", "Label"],"border_radius": "100px","padding": "8px 16px"},"leaderboard_item": {"layout": "Flexbox Row","a